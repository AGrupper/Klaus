# Application Settings
ENVIRONMENT=development # or production
TZ=Asia/Jerusalem

# Smart Agent — Gemini 3 Flash (the brain: orchestrates, judges, crafts responses)
SMART_AGENT_BACKEND=gemini
SMART_AGENT_MODEL=gemini-3-flash-preview
SMART_AGENT_API_KEY=your_google_ai_studio_key

# Smart Agent Fallback (optional) — activates automatically if the primary is down.
# If all three vars are set, the orchestrator retries with this model on LLM errors.
SMART_AGENT_FALLBACK_BACKEND=anthropic
SMART_AGENT_FALLBACK_MODEL=claude-haiku-4-5
SMART_AGENT_FALLBACK_API_KEY=your_anthropic_api_key

# Worker Agent — Gemini Flash (the hands: executes tools, does data gathering)
# API key is from Google AI Studio (aistudio.google.com), NOT Google Cloud.
WORKER_AGENT_BACKEND=gemini
WORKER_AGENT_MODEL=gemini-2.5-flash
WORKER_AGENT_API_KEY=your_google_ai_studio_key

# Telegram Bot Interface
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your personal Telegram user ID — get it from @userinfobot. Comma-separated for multiple.
TELEGRAM_ALLOWED_USER_IDS=your_telegram_user_id

# Google Cloud OAuth & Firebase
GCP_PROJECT_ID=your_gcp_project_id
GOOGLE_APPLICATION_CREDENTIALS=./config/credentials.json
GOOGLE_TOKEN_PATH=./config/token.json

# Memory Databases
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=klaus-memory

# Phase 6: Conversation persistence backend — "memory" for local dev, "firestore" for cloud
CONVERSATION_STORE=memory

# Number of hours of inactivity before a conversation session resets
SESSION_TIMEOUT_HOURS=6

# Firestore (conversation store, roster, attendance)
# Path to a service-account JSON with roles/datastore.user.
# Kept separate from GOOGLE_APPLICATION_CREDENTIALS (which is the OAuth client-secrets
# file used by Gmail/Calendar) — the two formats are incompatible with ADC.
FIRESTORE_CREDENTIALS=./config/firestore-service-account.json
FIRESTORE_DATABASE=your_firestore_database_name

# TickTick task backend (replaces Phase 4 Things 3 queue)
# Register a developer app at https://developer.ticktick.com/ to get client_id/secret.
# Run scripts/ticktick_oauth_bootstrap.py to obtain the initial token pair.
TICKTICK_CLIENT_ID=your_ticktick_client_id
TICKTICK_CLIENT_SECRET=your_ticktick_client_secret
TICKTICK_TOKEN_STORAGE=file                                   # "file" (dev) or "secret_manager" (Cloud Run)
TICKTICK_TOKEN_PATH=./config/ticktick_tokens.json             # populated by ticktick_oauth_bootstrap.py
TICKTICK_PROJECT_ID=                                          # optional; blank = Inbox
# Required when TICKTICK_TOKEN_STORAGE=secret_manager:
TICKTICK_ACCESS_TOKEN_SECRET=TICKTICK_ACCESS_TOKEN
TICKTICK_REFRESH_TOKEN_SECRET=TICKTICK_REFRESH_TOKEN

# Phase 5: Cloud Run deployment
# HTTP port (Cloud Run sets this automatically; 8080 is the default)
PORT=8080

# OAuth token storage backend: "file" (local dev) or "secret_manager" (Cloud Run)
GOOGLE_TOKEN_STORAGE=file

# Required when GOOGLE_TOKEN_STORAGE=secret_manager. Plain secret name (not full resource path).
# Example: GOOGLE_TOKEN_SECRET_NAME=klaus-google-oauth-token
GOOGLE_TOKEN_SECRET_NAME=

# Telegram webhook secret token — high-entropy random string that Telegram sends in
# X-Telegram-Bot-Api-Secret-Token on every webhook POST. Must match what you pass to
# setWebhook. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
TELEGRAM_WEBHOOK_SECRET=

# Phase 7: External connections — Garmin, Readwise, Weather

# Garmin Connect credentials (email/password — no OAuth available for Connect API)
GARMIN_EMAIL=your_garmin_email
GARMIN_PASSWORD=your_garmin_password

# Readwise API token — get from https://readwise.io/access_token
READWISE_TOKEN=your_readwise_token

# Phase 8: Five Fingers cron endpoints (Cloud Scheduler → OIDC → Cloud Run)

# Cloud Run service URL — used as the OIDC token audience for /cron/* auth.
CLOUD_RUN_URL=

# Service account email that Cloud Scheduler uses to call /cron/* routes.
# Must match the SA attached to the Cloud Scheduler jobs.
CLOUD_SCHEDULER_SA_EMAIL=

# Set to "true" in local dev to skip OIDC verification on /cron/* routes.
CRON_DEV_BYPASS=false

# Phase 9: Proactive Alerts
PROACTIVE_RAIN_THRESHOLD=20          # Rain chance % that triggers weather alert
PROACTIVE_TEMP_MAX=38                # Celsius — flag extreme heat
PROACTIVE_TEMP_MIN=8                 # Celsius — flag extreme cold
PROACTIVE_FREE_TIME_MIN=60           # Minutes — total free time below this = overloaded
PROACTIVE_GAP_MIN=30                 # Minutes — longest gap below this = overloaded
HOME_ADDRESS=                        # Or store in Secret Manager as "klaus-home-address"

# Phase 11: Notion integration
# Create an internal integration at https://www.notion.so/my-integrations
# Share your PARA databases (Projects, Areas, Resources, Archives) with the integration
# The token does not expire — no refresh script needed
NOTION_API_TOKEN=your_notion_internal_integration_token
NOTION_JOURNAL_DB_ID=                 # optional — your journal/daily-log database ID for reliable append-to-journal workflows

# Phase 12: Claude Code chat-log ingestion
# GCS bucket where local upload scripts push raw JSONL files
CHAT_LOGS_BUCKET=                             # e.g. "klaus-chat-logs-your-project-id"
# Notion database ID for the chat-log summary table (one row per conversation)
# Create the DB manually: Name (title), Date (date), Project (select), Summary (rich_text),
# Topics (multi_select), Machine (select), Session ID (rich_text)
NOTION_CHAT_LOG_DB_ID=                        # your Notion chat-log database ID
# Optional tuning (defaults: 8 files, 45s)
CHAT_INGEST_BATCH_MAX_FILES=8
CHAT_INGEST_TIME_BUDGET_SEC=45
