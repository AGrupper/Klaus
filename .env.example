# Application Settings
ENVIRONMENT=development # or production
TZ=Asia/Jerusalem

# Smart Agent — Claude (the brain: orchestrates, judges, crafts responses)
SMART_AGENT_BACKEND=anthropic
SMART_AGENT_MODEL=claude-opus-4-5-20251101
SMART_AGENT_API_KEY=your_anthropic_api_key

# Worker Agent — Gemini Flash (the hands: executes tools, does data gathering)
# API key is from Google AI Studio (aistudio.google.com), NOT Google Cloud.
WORKER_AGENT_BACKEND=gemini
WORKER_AGENT_MODEL=gemini-2.5-flash
WORKER_AGENT_API_KEY=your_google_ai_studio_key

# Telegram Bot Interface
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your personal Telegram user ID — get it from @userinfobot. Comma-separated for multiple.
TELEGRAM_ALLOWED_USER_IDS=your_telegram_user_id

# Google Cloud OAuth & Firebase
GCP_PROJECT_ID=your_gcp_project_id
GOOGLE_APPLICATION_CREDENTIALS=./config/credentials.json
GOOGLE_TOKEN_PATH=./config/token.json

# Memory Databases
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=klaus-memory

# Phase 6: Conversation persistence backend — "memory" for local dev, "firestore" for cloud
CONVERSATION_STORE=memory

# Phase 4: Things 3 cloud queue (Firestore)
# Path to a service-account JSON with roles/datastore.user.
# Kept separate from GOOGLE_APPLICATION_CREDENTIALS (which is the OAuth client-secrets
# file used by Gmail/Calendar) — the two formats are incompatible with ADC.
FIRESTORE_CREDENTIALS=./config/firestore-service-account.json
FIRESTORE_DATABASE=your_firestore_database_name
FIRESTORE_COLLECTION_THINGS_QUEUE=things_queue
THINGS_POLLER_INTERVAL_SECONDS=30

# Phase 5: Cloud Run deployment
# HTTP port (Cloud Run sets this automatically; 8080 is the default)
PORT=8080

# OAuth token storage backend: "file" (local dev) or "secret_manager" (Cloud Run)
GOOGLE_TOKEN_STORAGE=file

# Required when GOOGLE_TOKEN_STORAGE=secret_manager. Plain secret name (not full resource path).
# Example: GOOGLE_TOKEN_SECRET_NAME=klaus-google-oauth-token
GOOGLE_TOKEN_SECRET_NAME=

# Telegram webhook secret token — high-entropy random string that Telegram sends in
# X-Telegram-Bot-Api-Secret-Token on every webhook POST. Must match what you pass to
# setWebhook. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
TELEGRAM_WEBHOOK_SECRET=

# Phase 7: External connections — Garmin, Readwise, Weather

# Garmin Connect credentials (email/password — no OAuth available for Connect API)
GARMIN_EMAIL=your_garmin_email
GARMIN_PASSWORD=your_garmin_password

# Readwise API token — get from https://readwise.io/access_token
READWISE_TOKEN=your_readwise_token

# Phase 8: Five Fingers cron endpoints (Cloud Scheduler → OIDC → Cloud Run)

# Cloud Run service URL — used as the OIDC token audience for /cron/* auth.
CLOUD_RUN_URL=

# Service account email that Cloud Scheduler uses to call /cron/* routes.
# Must match the SA attached to the Cloud Scheduler jobs.
CLOUD_SCHEDULER_SA_EMAIL=

# Set to "true" in local dev to skip OIDC verification on /cron/* routes.
CRON_DEV_BYPASS=false
